{
  "version": 2,
  "builds": [
    {
      "src": "/*",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "VITE_API_URL": "@Test-spiel-Edrick-backend.onrender.com"
  }
}
